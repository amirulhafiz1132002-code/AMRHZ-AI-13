# =========================
# ?? SERVER CONFIG
# =========================
HOST=0.0.0.0
PORT=8000
ENV=development

# =========================
# ?? AI / MODEL CONFIG
# =========================
MODEL_NAME=all-MiniLM-L6-v2
USE_LOCAL_MODEL=true

# Optional (if upgrade later)
OPENAI_API_KEY=
HUGGINGFACE_API_KEY=

# =========================
# ?? VECTOR MEMORY (RAG)
# =========================
VECTOR_DB=faiss
VECTOR_DIM=384
MEMORY_PATH=./data/memory.json

# =========================
# ?? AGENT SYSTEM
# =========================
ENABLE_MULTI_AGENT=true
AGENT_MODE=standard

# =========================
# ?? VOICE SYSTEM
# =========================
ENABLE_VOICE=true
VOICE_ENGINE=pyttsx3

# =========================
# ?? FRONTEND / AP1 CONNECT
# =========================
FRONTEND_URL=http://localhost:8000
API_BASE_URL=http://localhost:8000

# =========================
# ?? DEPLOYMENT
# =========================
DEPLOY_ENV=local
RENDER=false
RAILWAY=false

# =========================
# ?? SECURITY (OPTIONAL)
# =========================
API_KEY=amrhz-secure-key
ALLOW_ORIGINS=*

# =========================
# ? AUTO LEARNING
# =========================
AUTO_LEARN=true
SAVE_HISTORY=true
